local FLOAT = TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

---@param obj Instance
---@param info TweenInfo
---@param props table
---@return Tween
local function tween(obj, info, props)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

