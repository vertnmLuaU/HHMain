local BASE_RES = 1080

---@return number
local function getScale()
	local vp = camera.ViewportSize
	return math.clamp(math.min(vp.X, vp.Y) / BASE_RES, 0.4, 2.5)
end

local S = getScale()
---@param n number
---@return number
local function px(n) return
math.round(n * S)
end

camera:GetPropertyChangedSignal("ViewportSize"):Connect(function() S = getScale() end)

