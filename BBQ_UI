		---@param opts {Text:string?, SubText:string?, Default:boolean?, Callback:function(boolean)?}
		---@return table
		function Tab:CreateToggle(opts)
			opts = opts or {}
			local state = opts.Default or false
			local cardH = opts.SubText and 56 or 46
			local card = baseCard(cardH)
			cardHover(card)

			local txt = Instance.new("TextLabel")
			txt.Size = UDim2.new(1, -80, 0, 18)
			txt.BackgroundTransparency = 1
			txt.Font = Enum.Font.GothamMedium
			txt.Text = opts.Text or "Toggle"
			txt.TextColor3 = Theme.Text
			txt.TextSize = 13
			txt.TextXAlignment = Enum.TextXAlignment.Left
			txt.Parent = card

			if opts.SubText then
				txt.Position = UDim2.new(0, 14, 0, 10)
				local sub = Instance.new("TextLabel")
				sub.Size = UDim2.new(1, -80, 0, 14)
				sub.Position = UDim2.new(0, 14, 0, 30)
				sub.BackgroundTransparency = 1
				sub.Font = Enum.Font.Gotham
				sub.Text = opts.SubText
				sub.TextColor3 = Theme.TextMuted
				sub.TextSize = 11
				sub.TextXAlignment = Enum.TextXAlignment.Left
				sub.Parent = card
			else
				txt.Position = UDim2.new(0, 14, 0.5, -9)
			end

			local TRACK_W, TRACK_H = 42, 22
			local track = Instance.new("TextButton")
			track.Size = UDim2.new(0, TRACK_W, 0, TRACK_H)
			track.Position = UDim2.new(1, -(TRACK_W + 14), 0.5, -TRACK_H / 2)
			track.BackgroundColor3 = Theme.TrackOff
			track.AutoButtonColor = false
			track.Text = ""
			track.BorderSizePixel = 0
			track.Parent = card
			corner(track, TRACK_H / 2)

			local KNOB = 16
			local knob = Instance.new("Frame")
			knob.Size = UDim2.new(0, KNOB, 0, KNOB)
			knob.Position = UDim2.new(0, 3, 0.5, -KNOB / 2)
			knob.BackgroundColor3 = Color3.fromRGB(200, 200, 205)
			knob.BorderSizePixel = 0
			knob.Parent = track
			corner(knob, KNOB / 2)

			---@param animate boolean
			local function visual(animate)
				local info = animate and SMOOTH or TweenInfo.new(0)
				if state then
					tween(track, info, { BackgroundColor3 = Theme.TrackOn })
					tween(knob, animate and SPRING or info, {
						Position = UDim2.new(1, -(KNOB + 3), 0.5, -KNOB / 2),
						BackgroundColor3 = Color3.fromRGB(240, 240, 245)
					})
				else
					tween(track, info, { BackgroundColor3 = Theme.TrackOff })
					tween(knob, animate and SPRING or info, {
						Position = UDim2.new(0, 3, 0.5, -KNOB / 2),
						BackgroundColor3 = Color3.fromRGB(120, 120, 130)
					})
				end
			end
			visual(false)

			local function flip()
				state = not state
				visual(true)
				if opts.Callback then task.spawn(opts.Callback, state) end
			end
			track.MouseButton1Click:Connect(flip)

			local api = {}
			---@param v boolean
			function api:Set(v)
				state = v and true or false
				visual(true)
				if opts.Callback then task.spawn(opts.Callback, state) end
			end
			---@return boolean
			function api:Get() return state end
			return api
		end

		---@param opts {Text:string?, Min:number?, Max:number?, Decimals:number?, Default:number?, Callback:function(number)?}
		---@return table
		function Tab:CreateSlider(opts)
			opts = opts or {}
			local minV = opts.Min or 0
			local maxV = opts.Max or 100
			local decs = opts.Decimals or 0
			local value = math.clamp(opts.Default or minV, minV, maxV)
			local card = baseCard(58)
			cardHover(card)

			local txt = Instance.new("TextLabel")
			txt.Size = UDim2.new(1, -80, 0, 20)
			txt.Position = UDim2.new(0, 14, 0, 10)
			txt.BackgroundTransparency = 1
			txt.Font = Enum.Font.GothamMedium
			txt.Text = opts.Text or "Slider"
			txt.TextColor3 = Theme.Text
			txt.TextSize = 13
			txt.TextXAlignment = Enum.TextXAlignment.Left
			txt.Parent = card

			local valLbl = Instance.new("TextLabel")
			valLbl.Size = UDim2.new(0, 56, 0, 20)
			valLbl.Position = UDim2.new(1, -70, 0, 10)
			valLbl.BackgroundTransparency = 1
			valLbl.Font = Enum.Font.GothamBold
			valLbl.Text = tostring(value)
			valLbl.TextColor3 = Theme.Text
			valLbl.TextSize = 13
			valLbl.TextXAlignment = Enum.TextXAlignment.Right
			valLbl.Parent = card

			local barBg = Instance.new("Frame")
			barBg.Size = UDim2.new(1, -28, 0, 4)
			barBg.Position = UDim2.new(0, 14, 0, 40)
			barBg.BackgroundColor3 = Theme.Stroke
			barBg.BorderSizePixel = 0
			barBg.Parent = card
			corner(barBg, 2)

			local fill = Instance.new("Frame")
			fill.Size = UDim2.new(math.clamp((value - minV) / (maxV - minV), 0, 1), 0, 1, 0)
			fill.BackgroundColor3 = Theme.Purple
			fill.BorderSizePixel = 0
			fill.Parent = barBg
			corner(fill, 2)

			local KNOB = 12
			local sliderKnob = Instance.new("Frame")
			sliderKnob.Size = UDim2.new(0, KNOB, 0, KNOB)
			sliderKnob.AnchorPoint = Vector2.new(0.5, 0.5)
			sliderKnob.Position = UDim2.new(1, 0, 0.5, 0)
			sliderKnob.BackgroundColor3 = Color3.fromRGB(230, 230, 235)
			sliderKnob.BorderSizePixel = 0
			sliderKnob.ZIndex = 3
			sliderKnob.Parent = fill
			corner(sliderKnob, KNOB / 2)

			local dragging = false

			---@param n number
			---@return number
			local function roundVal(n)
				local m = 10 ^ decs
				return math.floor(n * m + 0.5) / m
			end

			---@param x number
			local function setFromX(x)
				local rel = math.clamp((x - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X, 0, 1)
				value = roundVal(minV + (maxV - minV) * rel)
				valLbl.Text = tostring(value)
				tween(fill, FAST, { Size = UDim2.new(rel, 0, 1, 0) })
				if opts.Callback then task.spawn(opts.Callback, value) end
			end

			barBg.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					setFromX(input.Position.X)
				end
			end)
			card.InputBegan:Connect(function(input)
				if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch)
					and input.Position.Y >= barBg.AbsolutePosition.Y - 10 then
					dragging = true
					setFromX(input.Position.X)
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					setFromX(input.Position.X)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			local api = {}
			---@param v number
			function api:Set(v)
				value = math.clamp(roundVal(v), minV, maxV)
				local rel = (value - minV) / (maxV - minV)
				valLbl.Text = tostring(value)
				tween(fill, SMOOTH, { Size = UDim2.new(rel, 0, 1, 0) })
				if opts.Callback then task.spawn(opts.Callback, value) end
			end
			---@return number
			function api:Get() return value end
			return api
		end

		---@param opts {Text:string?, Options:string[]?, Default:string?, Callback:function(string)?}
		---@return table
		function Tab:CreateDropdown(opts)
			opts = opts or {}
			local options = opts.Options or {}
			local selected = opts.Default or (options[1] or "Select")
			local open = false

			local card = baseCard(42)
			card.ClipsDescendants = true

			local header = Instance.new("TextButton")
			header.Size = UDim2.new(1, 0, 0, 42)
			header.BackgroundTransparency = 1
			header.Text = ""
			header.Parent = card

			local txt = Instance.new("TextLabel")
			txt.Size = UDim2.new(1, -90, 0, 42)
			txt.Position = UDim2.new(0, 14, 0, 0)
			txt.BackgroundTransparency = 1
			txt.Font = Enum.Font.GothamMedium
			txt.Text = opts.Text or "Dropdown"
			txt.TextColor3 = Theme.Text
			txt.TextSize = 13
			txt.TextXAlignment = Enum.TextXAlignment.Left
			txt.Parent = card

			local valLbl = Instance.new("TextLabel")
			valLbl.Size = UDim2.new(0, 100, 0, 42)
			valLbl.Position = UDim2.new(1, -126, 0, 0)
			valLbl.BackgroundTransparency = 1
			valLbl.Font = Enum.Font.Gotham
			valLbl.Text = tostring(selected)
			valLbl.TextColor3 = Theme.TextDim
			valLbl.TextSize = 12
			valLbl.TextXAlignment = Enum.TextXAlignment.Right
			valLbl.TextTruncate = Enum.TextTruncate.AtEnd
			valLbl.Parent = card

			local arrow = Instance.new("TextLabel")
			arrow.Size = UDim2.new(0, 18, 0, 42)
			arrow.Position = UDim2.new(1, -26, 0, 0)
			arrow.BackgroundTransparency = 1
			arrow.Font = Enum.Font.GothamBold
			arrow.Text = "∨"
			arrow.TextColor3 = Theme.TextDim
			arrow.TextSize = 12
			arrow.Parent = card

			local listHolder = Instance.new("Frame")
			listHolder.Size = UDim2.new(1, -20, 0, 0)
			listHolder.Position = UDim2.new(0, 10, 0, 42)
			listHolder.BackgroundTransparency = 1
			listHolder.Parent = card

			local listLayout = Instance.new("UIListLayout")
			listLayout.Padding = UDim.new(0, 3)
			listLayout.SortOrder = Enum.SortOrder.LayoutOrder
			listLayout.Parent = listHolder

			local function rebuild()
				for _, c in ipairs(listHolder:GetChildren()) do
					if c:IsA("TextButton") then c:Destroy() end
				end
				for _, opt in ipairs(options) do
					local o = Instance.new("TextButton")
					o.Size = UDim2.new(1, 0, 0, 30)
					o.BackgroundColor3 = Theme.Background
					o.AutoButtonColor = false
					o.Font = Enum.Font.Gotham
					o.Text = tostring(opt)
					o.TextColor3 = (opt == selected) and Theme.Text or Theme.TextDim
					o.TextSize = 12
					o.BorderSizePixel = 0
					o.Parent = listHolder
					corner(o, 7)
					o.MouseEnter:Connect(function() tween(o, FAST, { BackgroundColor3 = Theme.CardHover }) end)
					o.MouseLeave:Connect(function() tween(o, FAST, { BackgroundColor3 = Theme.Background }) end)
					o.MouseButton1Click:Connect(function()
						selected = opt
						valLbl.Text = tostring(opt)
						for _, c2 in ipairs(listHolder:GetChildren()) do
							if c2:IsA("TextButton") then
								c2.TextColor3 = (c2.Text == tostring(selected)) and Theme.Text or Theme.TextDim
							end
						end
						open = false
						tween(card, SMOOTH, { Size = UDim2.new(1, 0, 0, 42) })
						tween(arrow, SMOOTH, { Rotation = 0 })
						if opts.Callback then task.spawn(opts.Callback, selected) end
					end)
				end
			end
			rebuild()

			header.MouseButton1Click:Connect(function()
				open = not open
				if open then
					local h = 42 + (#options * 33) + 10
					tween(card, SMOOTH, { Size = UDim2.new(1, 0, 0, h) })
					tween(arrow, SMOOTH, { Rotation = 180 })
				else
					tween(card, SMOOTH, { Size = UDim2.new(1, 0, 0, 42) })
					tween(arrow, SMOOTH, { Rotation = 0 })
				end
			end)

			local api = {}
			---@param v string
			function api:Set(v)
				selected = v
				valLbl.Text = tostring(v)
				rebuild()
				if opts.Callback then task.spawn(opts.Callback, selected) end
			end
			---@return string
			function api:Get() return selected end
			---@param newOpts string[]
			function api:Refresh(newOpts) options = newOpts or {}; rebuild() end
			return api
		end

		---@param opts {Text:string?, Placeholder:string?, Default:string?, Callback:function(string, boolean)?}
		---@return table
		function Tab:CreateTextbox(opts)
			opts = opts or {}
			local card = baseCard(46)
			cardHover(card)

			local txt = Instance.new("TextLabel")
			txt.Size = UDim2.new(0.42, -14, 1, 0)
			txt.Position = UDim2.new(0, 14, 0, 0)
			txt.BackgroundTransparency = 1
			txt.Font = Enum.Font.GothamMedium
			txt.Text = opts.Text or "Textbox"
			txt.TextColor3 = Theme.Text
			txt.TextSize = 13
			txt.TextXAlignment = Enum.TextXAlignment.Left
			txt.Parent = card

			local boxBg = Instance.new("Frame")
			boxBg.Size = UDim2.new(0.58, -18, 0, 28)
			boxBg.Position = UDim2.new(0.42, 4, 0.5, -14)
			boxBg.BackgroundColor3 = Theme.Background
			boxBg.BorderSizePixel = 0
			boxBg.Parent = card
			corner(boxBg, 7)
			local boxStroke = uiStroke(boxBg, Theme.Stroke, 1, 0.3)

			local input = Instance.new("TextBox")
			input.Size = UDim2.new(1, -16, 1, 0)
			input.Position = UDim2.new(0, 8, 0, 0)
			input.BackgroundTransparency = 1
			input.Font = Enum.Font.Gotham
			input.Text = opts.Default or ""
			input.PlaceholderText = opts.Placeholder or "Enter text…"
			input.PlaceholderColor3 = Theme.TextMuted
			input.TextColor3 = Theme.Text
			input.TextSize = 12
			input.TextXAlignment = Enum.TextXAlignment.Left
			input.ClearTextOnFocus = false
			input.Parent = boxBg

			input.Focused:Connect(function()
				tween(boxStroke, FAST, { Color = Theme.Purple, Thickness = 1.5 })
			end)
			input.FocusLost:Connect(function(enter)
				tween(boxStroke, FAST, { Color = Theme.Stroke, Thickness = 1 })
				if opts.Callback then task.spawn(opts.Callback, input.Text, enter) end
			end)

			local api = {}
			---@param t string
			function api:Set(t) input.Text = t end
			---@return string
			function api:Get() return input.Text end
			return api
		end

		table.insert(allTabs, Tab)
		if #allTabs == 1 then task.defer(function() selectTab(Tab) end) end
		return Tab
	end

	tween(Main, SPRING, { Size = savedSize })

	local TOGGLE_KEY = Enum.KeyCode.RightShift
	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == TOGGLE_KEY then
			guiVisible = not guiVisible
			if guiVisible then
				Main.Visible = true
				Main.Size = UDim2.new(0, 0, 0, 0)
				tween(Main, SPRING, { Size = savedSize })
			else
				tween(Main, SMOOTH, { Size = UDim2.new(0, 0, 0, 0) }).Completed:Connect(function()
					if not guiVisible then Main.Visible = false end
				end)
			end
		end
	end)

	return {
		CreateTab = createTab,
		Theme = Theme,
	}
end

return CreateUI()
