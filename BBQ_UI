	---@param tab table
	local function selectTab(tab)
		if activeTab == tab then return end
		if activeTab then
			local prev = activeTab
			tween(prev._btn, FAST, { BackgroundTransparency = 1, BackgroundColor3 = Theme.Card })
			local prevLbl = prev._btn:FindFirstChildOfClass("TextLabel")
			local prevIcon = prev._btn:FindFirstChildOfClass("ImageLabel")
			local prevInd = prev._btn:FindFirstChildOfClass("Frame")
			if prevLbl then tween(prevLbl, FAST, { TextColor3 = Theme.TextDim }) end
			if prevIcon then tween(prevIcon, FAST, { ImageColor3 = Theme.TextDim }) end
			if prevInd then tween(prevInd, SMOOTH, { Size = UDim2.new(0, 3, 0, 0) }) end
			prev._page.Visible = false
		end
		activeTab = tab
		PageTitle.Text = tab.Name

		tween(tab._btn, FAST, { BackgroundTransparency = 0, BackgroundColor3 = Theme.Card })
		local lbl = tab._btn:FindFirstChildOfClass("TextLabel")
		local icon = tab._btn:FindFirstChildOfClass("ImageLabel")
		local ind = tab._btn:FindFirstChildOfClass("Frame")
		if lbl then tween(lbl, FAST, { TextColor3 = Theme.Text }) end
		if icon then tween(icon, FAST, { ImageColor3 = Theme.Yellow }) end
		if ind then tween(ind, SMOOTH, { Size = UDim2.new(0, 3, 0, 22) }) end

		tab._page.Visible = true
		tab._page.Position = UDim2.new(0, 0, 0, 10)
		tween(tab._page, FLOAT, { Position = UDim2.new(0, 0, 0, 0) })
	end

