---@param parent Instance
---@param radius number|nil
---@return UICorner
local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 12)
	c.Parent = parent
	return c
end

---@param parent Instance
---@param color Color3|nil
---@param thickness number|nil
---@param transparency number|nil
---@return UIStroke
local function uiStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or Theme.Stroke
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

---@param parent Instance
---@param all number|nil
---@param l number|nil
---@param r number|nil
---@param t number|nil
---@param b number|nil
---@return UIPadding
local function uiPadding(parent, all, l, r, t, b)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, l or all or 0)
	p.PaddingRight = UDim.new(0, r or all or 0)
	p.PaddingTop = UDim.new(0, t or all or 0)
	p.PaddingBottom = UDim.new(0, b or all or 0)
	p.Parent = parent
	return p
end

---@param frame Frame
---@param handle GuiObject|nil
local function makeDraggable(frame, handle)
	handle = handle or frame
	local dragging, dragStart, startPos
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			tween(frame, FAST, {
				Position = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y
				)
			})
		end
	end)
end

---@param name string|nil
---@return ScreenGui
local function getParentGui(name)
	local gui = Instance.new("ScreenGui")
	gui.Name = name or ("BBQHub_" .. tostring(math.random(1000, 9999)))
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.IgnoreGuiInset = true
	local ok, err = pcall(function()
		if gethui then
			gui.Parent = gethui()
		elseif syn and syn.protect_gui then
			syn.protect_gui(gui)
			gui.Parent = CoreGui
		else
			gui.Parent = CoreGui
		end
	end)
	if not ok then
		gui.Parent = (LocalPlayer and LocalPlayer:FindFirstChildOfClass("PlayerGui")) or CoreGui
	end
	return gui
end

